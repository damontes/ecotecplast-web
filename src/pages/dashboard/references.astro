---
import DashboardLayout from '@/dashboard/layouts/DashboardLayout.astro'
import Card from '@/dashboard/components/ui/Card.astro'
---

<DashboardLayout title='Colores de Referencia' active='references'>
  <div class='mb-6 flex items-start justify-between gap-4'>
    <div>
      <div class='text-[10px] font-semibold uppercase tracking-widest text-slate-400'>
        Ecotecplast ColorHub
      </div>
      <h1 class='text-2xl font-bold text-slate-900'>Colores de Referencia</h1>
      <p class='mt-1 text-sm text-slate-500'>
        Biblioteca curada de colores estándar usada para sugerir alternativas cuando un objetivo cae fuera del gamut.
      </p>
    </div>
    <div class='flex flex-shrink-0 items-center gap-2'>
      <div class='group relative'>
        <button
          type='button'
          class='rounded-full p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-600 focus:outline-none focus:ring-2 focus:ring-slate-300'
          aria-label='Ayuda: cuándo agregar un nuevo color'
        >
          <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='h-4 w-4'>
            <circle cx='12' cy='12' r='10'></circle>
            <line x1='12' y1='16' x2='12' y2='12'></line>
            <line x1='12' y1='8' x2='12.01' y2='8'></line>
          </svg>
        </button>
        <div class='pointer-events-none invisible absolute right-0 top-full z-10 mt-1 w-72 rounded-lg bg-slate-900 p-3 text-[11px] leading-relaxed text-slate-100 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100'>
          Usa <b>Nuevo color</b> cuando un cliente traiga su propio catálogo (Pantone medido, catálogo interno) y quieras que aparezca en las sugerencias. Ponlo bajo su propia paleta (ej. <code class='rounded bg-white/10 px-1 py-0.5'>Pantone-ClienteXYZ</code>) para separarlo de RAL.
        </div>
      </div>
      <button
        id='open-new-ref'
        type='button'
        class='inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-700 focus:ring-offset-2'
      >
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='h-4 w-4'>
          <line x1='12' y1='5' x2='12' y2='19'></line>
          <line x1='5' y1='12' x2='19' y2='12'></line>
        </svg>
        Nuevo color
      </button>
    </div>
  </div>

  {/* Persistent info banner — explains what this page feeds into. */}
  <div class='mb-6 flex gap-3 rounded-lg border border-sky-200 bg-sky-50 p-4'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      class='mt-0.5 h-5 w-5 flex-shrink-0 text-sky-600'
      aria-hidden='true'
    >
      <circle cx='12' cy='12' r='10'></circle>
      <line x1='12' y1='16' x2='12' y2='12'></line>
      <line x1='12' y1='8' x2='12.01' y2='8'></line>
    </svg>
    <div class='text-xs leading-relaxed text-sky-900'>
      <div class='mb-1 text-sm font-bold'>¿Cómo funciona esta biblioteca?</div>
      <p>
        Cuando el <b>Igualador de Color</b> no puede alcanzar el objetivo con tu inventario, revisa esta biblioteca y sugiere los colores más cercanos que <em>sí</em> puedes producir con tus masterbatches actuales. El cliente recibe recomendaciones concretas como <span class='rounded bg-white px-1 py-0.5 font-mono text-[10px] text-sky-800'>RAL 2011 Deep Orange</span> con la receta exacta.
      </p>
      <p class='mt-1.5'>
        La paleta <b>RAL</b> viene precargada — es un estándar industrial reconocido. Para catálogos específicos por cliente (Pantone medido, colores internos), usa <b>Nuevo color</b> arriba y agrégalos bajo una paleta propia.
      </p>
    </div>
  </div>

  <Card title='Biblioteca de Colores' eyebrow='Cargando…'>
    <div class='mb-5 grid gap-3 sm:grid-cols-2'>
      <div>
        <label for='filter-palette' class='ch-label'>Paleta</label>
        <select id='filter-palette' class='ch-input'>
          <option value=''>Todas las paletas</option>
        </select>
      </div>
      <div>
        <label for='filter-search' class='ch-label'>Buscar</label>
        <input id='filter-search' type='search' placeholder='Código o nombre…' class='ch-input' />
      </div>
    </div>

    {/* Fan-deck-style grid, populated at runtime and grouped by palette. */}
    <div id='refs-grid' class='space-y-8'>
      {/* Skeleton — replaced after fetch */}
      <div>
        <div class='mb-3 flex items-center gap-3'>
          <div class='h-3 w-24 animate-pulse rounded bg-slate-200' />
          <div class='h-3 w-8 animate-pulse rounded bg-slate-200' />
        </div>
        <div class='grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6'>
          {Array.from({ length: 8 }).map(() => (
            <div class='overflow-hidden rounded-lg ring-1 ring-slate-200'>
              <div class='aspect-[4/3] animate-pulse bg-slate-200' />
              <div class='space-y-1 p-2'>
                <div class='h-3 w-16 animate-pulse rounded bg-slate-200' />
                <div class='h-2.5 w-20 animate-pulse rounded bg-slate-200' />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div id='no-results' class='hidden px-3 py-6 text-center text-xs text-slate-400'>
      Ningún color coincide con los filtros.
    </div>
    <div id='empty-state' class='hidden px-3 py-6 text-center text-xs text-slate-400'>
      Aún no hay colores de referencia. Haz clic en <b>Nuevo color</b> para agregar el primero.
    </div>
  </Card>

  {/* Existing-palettes datalist populated after load */}
  <datalist id='existing-palettes'></datalist>

  {/* New Color Reference modal */}
  <dialog
    id='new-ref-modal'
    class='fixed inset-0 m-auto w-full max-w-md rounded-2xl bg-white p-0 shadow-2xl backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm'
  >
    <form id='new-ref-form' class='divide-y divide-slate-100'>
      <header class='flex items-center justify-between px-6 py-4'>
        <div>
          <h2 class='text-base font-bold text-slate-900'>Nuevo color de referencia</h2>
          <p class='mt-0.5 text-xs text-slate-500'>Agrega un color a la biblioteca de sugerencias.</p>
        </div>
        <button
          type='button'
          id='close-new-ref'
          class='rounded-md p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600'
          aria-label='Cerrar'
        >
          <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='h-5 w-5'>
            <line x1='18' y1='6' x2='6' y2='18'></line>
            <line x1='6' y1='6' x2='18' y2='18'></line>
          </svg>
        </button>
      </header>

      <div class='space-y-4 px-6 py-5'>
        <div>
          <label for='new-ref-palette' class='ch-label'>Paleta *</label>
          <input
            id='new-ref-palette'
            name='palette'
            type='text'
            list='existing-palettes'
            required
            class='ch-input'
            placeholder='ej. Internal, RAL, Cliente-ABC'
          />
          <p class='mt-1 text-[11px] text-slate-500'>Elige una paleta existente o escribe un nombre nuevo.</p>
        </div>
        <div class='grid gap-4 sm:grid-cols-2'>
          <div>
            <label for='new-ref-code' class='ch-label'>Código *</label>
            <input id='new-ref-code' name='code' type='text' required class='ch-input' placeholder='ej. INT-RED-005' />
          </div>
          <div>
            <label for='new-ref-name' class='ch-label'>Nombre *</label>
            <input id='new-ref-name' name='name' type='text' required class='ch-input' placeholder='ej. Signal Red' />
          </div>
        </div>
        <div class='grid grid-cols-3 gap-3'>
          <div>
            <label for='new-ref-l' class='ch-label text-center'>L*</label>
            <input id='new-ref-l' name='lab_l' type='number' step='0.01' required class='ch-input text-center' placeholder='0.00' />
          </div>
          <div>
            <label for='new-ref-a' class='ch-label text-center'>a*</label>
            <input id='new-ref-a' name='lab_a' type='number' step='0.01' required class='ch-input text-center' placeholder='0.00' />
          </div>
          <div>
            <label for='new-ref-b' class='ch-label text-center'>b*</label>
            <input id='new-ref-b' name='lab_b' type='number' step='0.01' required class='ch-input text-center' placeholder='0.00' />
          </div>
        </div>
        <div>
          <div class='ch-label'>Vista previa</div>
          <div id='new-ref-preview' class='h-16 rounded-lg ring-1 ring-slate-200' style='background: rgb(200,200,200);'></div>
        </div>
        <div id='new-ref-error' class='hidden rounded-lg border border-rose-300 bg-rose-50 p-2.5 text-xs text-rose-900'></div>
      </div>

      <footer class='flex items-center justify-end gap-2 px-6 py-4'>
        <button
          type='button'
          id='cancel-new-ref'
          class='rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50'
        >
          Cancelar
        </button>
        <button
          type='submit'
          id='submit-new-ref'
          class='rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 disabled:opacity-60'
        >
          Agregar color
        </button>
      </footer>
    </form>
  </dialog>
</DashboardLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const grid = document.getElementById('refs-grid') as HTMLDivElement | null
    if (!grid) return
    const fPalette = document.getElementById('filter-palette') as HTMLSelectElement | null
    const fSearch = document.getElementById('filter-search') as HTMLInputElement | null
    const paletteList = document.getElementById('existing-palettes') as HTMLDataListElement | null
    const noResults = document.getElementById('no-results')
    const emptyState = document.getElementById('empty-state')

    // CIELAB (D65) → sRGB. Same conversion the matcher UI uses.
    const labToRgbCss = (l: number, a: number, b: number): string => {
      const fy = (l + 16) / 116
      const fx = a / 500 + fy
      const fz = fy - b / 200
      const eps = 216 / 24389
      const kappa = 24389 / 27
      const xr = fx ** 3 > eps ? fx ** 3 : (116 * fx - 16) / kappa
      const yr = l > 8 ? fy ** 3 : l / kappa
      const zr = fz ** 3 > eps ? fz ** 3 : (116 * fz - 16) / kappa
      const X = xr * 0.95047
      const Y = yr * 1.0
      const Z = zr * 1.08883
      let r = X * 3.2406 + Y * -1.5372 + Z * -0.4986
      let g = X * -0.9689 + Y * 1.8758 + Z * 0.0415
      let bl = X * 0.0557 + Y * -0.204 + Z * 1.057
      const toSrgb = (c: number) =>
        c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(Math.max(0, c), 1 / 2.4) - 0.055
      r = Math.round(Math.min(1, Math.max(0, toSrgb(r))) * 255)
      g = Math.round(Math.min(1, Math.max(0, toSrgb(g))) * 255)
      bl = Math.round(Math.min(1, Math.max(0, toSrgb(bl))) * 255)
      return `rgb(${r}, ${g}, ${bl})`
    }

    // Perceptual lightness → readable text on the chip. Bright chips get
    // dark text, dark chips get white text.
    const readableText = (l: number): string => (l > 55 ? 'text-slate-900' : 'text-white')

    interface RefRow {
      id: number
      palette: string
      code: string
      name: string
      lab_l: number
      lab_a: number
      lab_b: number
    }

    let allChips: HTMLElement[] = []
    let sections: HTMLElement[] = []

    const applyFilters = () => {
      const palette = fPalette?.value ?? ''
      const term = (fSearch?.value ?? '').trim().toLowerCase()
      let visible = 0

      allChips.forEach((chip) => {
        const rPal = chip.dataset.palette ?? ''
        const rHay = chip.dataset.search ?? ''
        const show = (palette === '' || rPal === palette) && (term === '' || rHay.includes(term))
        chip.hidden = !show
        if (show) visible++
      })
      // Hide entire section if all its chips are hidden.
      sections.forEach((section) => {
        const anyVisible = Array.from(section.querySelectorAll<HTMLElement>('[data-ref-chip]'))
          .some((c) => !c.hidden)
        section.hidden = !anyVisible
      })
      if (noResults) noResults.classList.toggle('hidden', visible > 0 || allChips.length === 0)
    }

    fPalette?.addEventListener('change', applyFilters)
    fSearch?.addEventListener('input', applyFilters)

    const renderGrid = (refs: RefRow[]) => {
      grid.innerHTML = ''
      allChips = []
      sections = []

      if (refs.length === 0) {
        emptyState?.classList.remove('hidden')
        return
      }

      // Collect unique palettes → filter select + datalist.
      const uniquePalettes = Array.from(new Set(refs.map((r) => r.palette))).sort()
      if (fPalette) {
        const prev = fPalette.value
        fPalette.innerHTML = '<option value="">Todas las paletas</option>'
        uniquePalettes.forEach((p) => {
          const opt = document.createElement('option')
          opt.value = p
          opt.textContent = p
          fPalette.appendChild(opt)
        })
        fPalette.value = prev
      }
      if (paletteList) {
        paletteList.innerHTML = ''
        uniquePalettes.forEach((p) => {
          const opt = document.createElement('option')
          opt.value = p
          paletteList.appendChild(opt)
        })
      }

      // Group refs by palette.
      const byPalette = new Map<string, RefRow[]>()
      refs.forEach((r) => {
        const arr = byPalette.get(r.palette) ?? []
        arr.push(r)
        byPalette.set(r.palette, arr)
      })

      // Render each palette as a section with a header + card grid.
      for (const palette of uniquePalettes) {
        const items = byPalette.get(palette) ?? []

        const section = document.createElement('section')
        section.dataset.paletteSection = palette

        section.innerHTML = `
          <header class='mb-3 flex items-center gap-3 border-b border-slate-100 pb-2'>
            <h3 class='text-xs font-bold uppercase tracking-widest text-slate-700'>${palette}</h3>
            <span class='rounded-md bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-500'>${items.length}</span>
          </header>
          <div class='grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6'></div>
        `

        const cardGrid = section.querySelector('div.grid') as HTMLDivElement

        items.forEach((r) => {
          const l = Number(r.lab_l)
          const a = Number(r.lab_a)
          const b = Number(r.lab_b)
          const swatch = labToRgbCss(l, a, b)
          const textCls = readableText(l)

          const chip = document.createElement('div')
          chip.dataset.refChip = ''
          chip.dataset.palette = palette
          chip.dataset.search = `${r.code} ${r.name} ${palette}`.toLowerCase()
          chip.className = 'group overflow-hidden rounded-lg ring-1 ring-slate-200 transition hover:ring-slate-300 hover:shadow-sm'

          chip.innerHTML = `
            <div class='relative aspect-[4/3]' style='background: ${swatch}'>
              <div class='absolute inset-x-0 bottom-0 flex items-center justify-between px-2 py-1.5 opacity-0 transition group-hover:opacity-100'>
                <span class='rounded bg-black/40 px-1.5 py-0.5 text-[10px] font-mono tabular-nums text-white backdrop-blur-sm'>
                  L ${l.toFixed(0)} · a ${a.toFixed(0)} · b ${b.toFixed(0)}
                </span>
              </div>
              <div class='absolute right-2 top-2 rounded bg-black/25 px-1.5 py-0.5 text-[10px] font-mono ${textCls} backdrop-blur-sm'>
                ${r.code}
              </div>
            </div>
            <div class='bg-white p-2'>
              <div class='truncate text-xs font-semibold text-slate-800' title='${r.name}'>${r.name}</div>
              <div class='truncate text-[10px] text-slate-500'>${palette}</div>
            </div>
          `
          cardGrid.appendChild(chip)
          allChips.push(chip)
        })

        grid.appendChild(section)
        sections.push(section)
      }

      applyFilters()
    }

    const load = () => {
      fetch('/api/color-references')
        .then((r) => r.json())
        .then((data) => {
          const refs = (data.color_references ?? []) as RefRow[]
          renderGrid(refs)
          const eyebrow = document.querySelector('[data-card-eyebrow]') as HTMLElement | null
          if (eyebrow) eyebrow.textContent = `${refs.length} total`
        })
        .catch(() => {
          grid.innerHTML = '<div class="px-3 py-6 text-center text-xs text-rose-600">Fallo al cargar la biblioteca.</div>'
        })
    }
    load()

    // --- Modal ---
    const modal = document.getElementById('new-ref-modal') as HTMLDialogElement | null
    const openBtn = document.getElementById('open-new-ref')
    const closeBtn = document.getElementById('close-new-ref')
    const cancelBtn = document.getElementById('cancel-new-ref')
    const form = document.getElementById('new-ref-form') as HTMLFormElement | null
    const errBox = document.getElementById('new-ref-error') as HTMLDivElement | null
    const submitBtn = document.getElementById('submit-new-ref') as HTMLButtonElement | null
    const preview = document.getElementById('new-ref-preview') as HTMLDivElement | null
    const inL = document.getElementById('new-ref-l') as HTMLInputElement | null
    const inA = document.getElementById('new-ref-a') as HTMLInputElement | null
    const inB = document.getElementById('new-ref-b') as HTMLInputElement | null

    const updatePreview = () => {
      const l = Number(inL?.value)
      const a = Number(inA?.value)
      const b = Number(inB?.value)
      if (!Number.isFinite(l) || !Number.isFinite(a) || !Number.isFinite(b)) return
      if (preview) preview.style.background = labToRgbCss(l, a, b)
    }
    inL?.addEventListener('input', updatePreview)
    inA?.addEventListener('input', updatePreview)
    inB?.addEventListener('input', updatePreview)

    const closeModal = () => {
      modal?.close()
      form?.reset()
      errBox?.classList.add('hidden')
      if (preview) preview.style.background = 'rgb(200,200,200)'
    }
    openBtn?.addEventListener('click', () => modal?.showModal())
    closeBtn?.addEventListener('click', closeModal)
    cancelBtn?.addEventListener('click', closeModal)
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) closeModal()
    })

    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (!form || !submitBtn) return
      errBox?.classList.add('hidden')

      const fd = new FormData(form)
      const payload = {
        palette: String(fd.get('palette') ?? '').trim(),
        code: String(fd.get('code') ?? '').trim(),
        name: String(fd.get('name') ?? '').trim(),
        lab_l: Number(fd.get('lab_l')),
        lab_a: Number(fd.get('lab_a')),
        lab_b: Number(fd.get('lab_b'))
      }

      if (!payload.palette || !payload.code || !payload.name) {
        if (errBox) {
          errBox.textContent = 'Paleta, código y nombre son obligatorios.'
          errBox.classList.remove('hidden')
        }
        return
      }
      if ([payload.lab_l, payload.lab_a, payload.lab_b].some((n) => !Number.isFinite(n))) {
        if (errBox) {
          errBox.textContent = 'Los valores L*, a*, b* deben ser números.'
          errBox.classList.remove('hidden')
        }
        return
      }

      submitBtn.disabled = true
      submitBtn.textContent = 'Agregando…'

      const resp = await fetch('/api/color-references', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload)
      })
      if (!resp.ok) {
        const body = (await resp.json().catch(() => ({}))) as { error?: string }
        if (errBox) {
          errBox.textContent =
            body?.error === 'palette_code_exists'
              ? 'Ya existe un color con ese código en la paleta.'
              : body?.error ?? `Error del servidor (${resp.status})`
          errBox.classList.remove('hidden')
        }
        submitBtn.disabled = false
        submitBtn.textContent = 'Agregar color'
        return
      }
      closeModal()
      submitBtn.disabled = false
      submitBtn.textContent = 'Agregar color'
      load()
    })
  })
</script>
