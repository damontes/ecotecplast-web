---
import DashboardLayout from '@/dashboard/layouts/DashboardLayout.astro'
import Card from '@/dashboard/components/ui/Card.astro'
import ConfirmDialog from '@/dashboard/components/ui/ConfirmDialog.astro'
---

<DashboardLayout
  title='Cliente'
  active='clients'
  breadcrumbLabels={{}}
>
  {/* Header skeleton — replaced after fetch */}
  <div id='client-header' class='mb-6 flex items-start justify-between gap-4'>
    <div>
      <div class='h-7 w-48 animate-pulse rounded bg-slate-200' />
      <div class='mt-2 h-4 w-64 animate-pulse rounded bg-slate-200' />
    </div>
    <div class='flex gap-4'>
      {Array.from({ length: 3 }).map(() => (
        <div class='text-right'>
          <div class='h-3 w-16 animate-pulse rounded bg-slate-200' />
          <div class='mt-1 h-7 w-10 animate-pulse rounded bg-slate-200' />
        </div>
      ))}
    </div>
  </div>

  {/* Info cards skeleton */}
  <div id='client-info' class='mb-6 grid gap-4 sm:grid-cols-3'>
    <div class='rounded-lg border border-slate-200 bg-white p-3'>
      <div class='ch-label'>Polímero por defecto</div>
      <div class='h-5 w-10 animate-pulse rounded bg-slate-200' />
    </div>
    <div class='rounded-lg border border-slate-200 bg-white p-3 sm:col-span-2'>
      <div class='ch-label'>Notas</div>
      <div class='h-4 w-64 animate-pulse rounded bg-slate-200' />
    </div>
  </div>

  <Card title='Historial de Trabajos' eyebrow='Cargando…'>
    <div class='grid gap-3 sm:grid-cols-3'>
      <div>
        <label for='filter-date-from' class='ch-label'>Desde</label>
        <input id='filter-date-from' type='date' class='ch-input' />
      </div>
      <div>
        <label for='filter-date-to' class='ch-label'>Hasta</label>
        <input id='filter-date-to' type='date' class='ch-input' />
      </div>
      <div>
        <label for='filter-status' class='ch-label'>Estado</label>
        <select id='filter-status' class='ch-input'>
          <option value=''>Todos</option>
          <option value='success'>Aprobado</option>
          <option value='failure'>Fuera de gamut</option>
        </select>
      </div>
    </div>

    <div class='mt-5 overflow-x-auto'>
      <table class='w-full text-sm'>
        <thead>
          <tr class='text-left text-[10px] font-semibold uppercase tracking-widest text-slate-400'>
            <th class='px-3 py-3'>Trabajo</th>
            <th class='px-3 py-3'>Fecha</th>
            <th class='px-3 py-3'>Polímero</th>
            <th class='px-3 py-3'>Color objetivo</th>
            <th class='px-3 py-3'>L a b</th>
            <th class='px-3 py-3 text-right'>ΔE</th>
            <th class='px-3 py-3 text-right'>Estado</th>
          </tr>
        </thead>
        <tbody id='jobs-tbody'>
          {Array.from({ length: 5 }).map(() => (
            <tr class='border-t border-slate-100 [&_td]:px-3 [&_td]:py-2.5'>
              <td><div class='h-3.5 w-20 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='h-3.5 w-24 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='h-3.5 w-10 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='h-5 w-8 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='h-3.5 w-28 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='ml-auto h-3.5 w-10 animate-pulse rounded bg-slate-200' /></td>
              <td><div class='ml-auto h-5 w-14 animate-pulse rounded-md bg-slate-200' /></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Card>

  {/* Edit modal */}
  <dialog
    id='edit-client-dialog'
    class='fixed inset-0 m-auto w-full max-w-lg rounded-2xl bg-white p-0 shadow-2xl backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm'
  >
    <div class='px-6 py-5'>
      <div class='flex items-center justify-between'>
        <h2 class='text-lg font-bold text-slate-900'>Editar cliente</h2>
        <button type='button' data-edit-close class='rounded-lg p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600'>
          <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='h-5 w-5'>
            <path d='M18 6 6 18'></path><path d='m6 6 12 12'></path>
          </svg>
        </button>
      </div>
      <form id='edit-client-form' class='mt-4 space-y-4' novalidate>
        <div>
          <label for='edit-name' class='ch-label'>Nombre *</label>
          <input id='edit-name' type='text' required class='ch-input' placeholder='Nombre del cliente' />
        </div>
        <div class='grid gap-4 sm:grid-cols-2'>
          <div>
            <label for='edit-email' class='ch-label'>Correo</label>
            <input id='edit-email' type='email' class='ch-input' placeholder='contacto@ejemplo.com' />
          </div>
          <div>
            <label for='edit-phone' class='ch-label'>Teléfono</label>
            <input id='edit-phone' type='tel' class='ch-input' placeholder='+52 …' />
          </div>
        </div>
        <div>
          <label for='edit-polymer' class='ch-label'>Polímero portador por defecto</label>
          <select id='edit-polymer' class='ch-input'>
            <option value=''>Polímero por defecto (opcional)</option>
            <option value='pe'>PE (Polietileno)</option>
            <option value='hdpe'>HDPE</option>
            <option value='pp'>PP (Polipropileno)</option>
            <option value='pet'>PET</option>
            <option value='abs'>ABS</option>
            <option value='ps'>PS (Poliestireno)</option>
          </select>
        </div>
        <div>
          <label for='edit-notes' class='ch-label'>Notas</label>
          <textarea id='edit-notes' rows='3' class='ch-input' placeholder='Notas internas opcionales' />
        </div>
        <div id='edit-error' class='hidden rounded-lg border border-rose-300 bg-rose-50 p-2.5 text-xs text-rose-900'></div>
      </form>
    </div>
    <footer class='flex items-center justify-between border-t border-slate-100 px-6 py-4'>
      <button type='button' id='delete-client-btn'
         class='inline-flex items-center gap-1.5 rounded-lg border border-rose-200 bg-white px-3.5 py-2 text-sm font-semibold text-rose-700 shadow-sm hover:bg-rose-50'>
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='h-4 w-4'>
          <path d='M3 6h18'></path>
          <path d='M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6'></path>
          <path d='M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2'></path>
        </svg>
        Eliminar
      </button>
      <div class='flex gap-2'>
        <button type='button' data-edit-close
           class='rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50'>
          Cancelar
        </button>
        <button type='submit' id='save-client-btn' form='edit-client-form'
           class='rounded-lg bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 disabled:opacity-60'>
          Guardar cambios
        </button>
      </div>
    </footer>
  </dialog>

  <ConfirmDialog
    id='delete-client-dialog'
    title='Eliminar cliente'
    message='Esta acción no se puede deshacer. Se eliminará el cliente y su historial de trabajos asociado.'
    confirmLabel='Eliminar'
  />
</DashboardLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    // URL guard — this listener persists across ClientRouter navigations,
    // so we must exit early if the current URL isn't the client detail
    // page, otherwise we'd hijack every unrelated navigation.
    if (!/^\/dashboard\/clients\/\d+\/?$/.test(window.location.pathname)) return
    const pathParts = window.location.pathname.replace(/\/$/, '').split('/')
    const clientId = Number(pathParts[pathParts.length - 1])
    if (!Number.isFinite(clientId)) return

    const headerEl = document.getElementById('client-header')
    const infoEl = document.getElementById('client-info')
    const tbody = document.getElementById('jobs-tbody') as HTMLTableSectionElement
    const fFrom = document.getElementById('filter-date-from') as HTMLInputElement
    const fTo = document.getElementById('filter-date-to') as HTMLInputElement
    const fStatus = document.getElementById('filter-status') as HTMLSelectElement
    const editDlg = document.getElementById('edit-client-dialog') as HTMLDialogElement | null
    const deleteDlg = document.getElementById('delete-client-dialog') as HTMLDialogElement | null
    const errBox = document.getElementById('edit-error')

    let clientData: Record<string, unknown> | null = null

    const fmt = (n: number | null) => (n == null ? '—' : n.toFixed(1))

    const labToRgbCss = (l: number | null, a: number | null, b: number | null): string => {
      if (l == null || a == null || b == null) return 'rgb(180,180,180)'
      const fy = (l + 16) / 116
      const fx = a / 500 + fy
      const fz = fy - b / 200
      const eps = 216 / 24389
      const kappa = 24389 / 27
      const xr = fx ** 3 > eps ? fx ** 3 : (116 * fx - 16) / kappa
      const yr = l > 8 ? fy ** 3 : l / kappa
      const zr = fz ** 3 > eps ? fz ** 3 : (116 * fz - 16) / kappa
      const X = xr * 0.95047
      const Y = yr * 1.0
      const Z = zr * 1.08883
      let r = X * 3.2406 + Y * -1.5372 + Z * -0.4986
      let g = X * -0.9689 + Y * 1.8758 + Z * 0.0415
      let bl = X * 0.0557 + Y * -0.204 + Z * 1.057
      const toSrgb = (c: number) =>
        c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(Math.max(0, c), 1 / 2.4) - 0.055
      r = Math.round(Math.min(1, Math.max(0, toSrgb(r))) * 255)
      g = Math.round(Math.min(1, Math.max(0, toSrgb(g))) * 255)
      bl = Math.round(Math.min(1, Math.max(0, toSrgb(bl))) * 255)
      return `rgb(${r}, ${g}, ${bl})`
    }

    const val = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null)?.value ?? ''
    const setVal = (id: string, v: string) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null
      if (el) el.value = v
    }

    const openEditModal = () => {
      if (!clientData || !editDlg) return
      const c = clientData as Record<string, unknown>
      setVal('edit-name', (c.name as string) ?? '')
      setVal('edit-email', (c.contact_email as string) ?? '')
      setVal('edit-phone', (c.contact_phone as string) ?? '')
      setVal('edit-polymer', (c.default_carrier_polymer as string) ?? '')
      setVal('edit-notes', (c.notes as string) ?? '')
      errBox?.classList.add('hidden')
      editDlg.showModal()
    }

    // Open/close modal
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      if (target.closest('#edit-client-btn')) openEditModal()
      if (target.closest('[data-edit-close]')) editDlg?.close()
    })

    editDlg?.addEventListener('click', (e) => {
      if (e.target === editDlg) editDlg.close()
    })

    // Submit edit
    const form = document.getElementById('edit-client-form') as HTMLFormElement | null
    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      errBox?.classList.add('hidden')

      const payload = {
        name: val('edit-name').trim(),
        contact_email: val('edit-email').trim() || null,
        contact_phone: val('edit-phone').trim() || null,
        default_carrier_polymer: val('edit-polymer') || null,
        notes: val('edit-notes').trim() || null
      }

      if (!payload.name) {
        if (errBox) { errBox.textContent = 'El nombre del cliente es obligatorio.'; errBox.classList.remove('hidden') }
        return
      }

      const saveBtn = document.getElementById('save-client-btn') as HTMLButtonElement | null
      if (saveBtn) { saveBtn.disabled = true; saveBtn.textContent = 'Guardando…' }

      const resp = await fetch(`/api/clients/${clientId}`, {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload)
      })

      if (!resp.ok) {
        const body = (await resp.json().catch(() => ({}))) as { error?: string }
        if (errBox) {
          errBox.textContent = body?.error === 'client_name_exists' ? 'Ya existe otro cliente con ese nombre.' : body?.error ?? `Error del servidor (${resp.status})`
          errBox.classList.remove('hidden')
        }
        if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Guardar cambios' }
        return
      }

      editDlg?.close()
      if (saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'Guardar cambios' }
      // Reload data
      window.location.reload()
    })

    // Delete handler
    deleteDlg?.addEventListener('confirm-ok', async () => {
      const resp = await fetch(`/api/clients/${clientId}`, { method: 'DELETE' })
      if (resp.ok) window.location.href = '/dashboard/clients'
    })
    document.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('#delete-client-btn')) {
        editDlg?.close()
        deleteDlg?.showModal()
      }
    })

    // --- Fetch client info + stats ---
    fetch(`/api/clients/${clientId}`)
      .then((r) => r.json())
      .then((data) => {
        if (data.error) {
          window.location.href = '/dashboard/clients'
          return
        }
        const c = data.client
        const s = data.stats
        clientData = c

        document.title = `${c.name} · Ecotecplast ColorHub`

        const bcId = document.querySelector(`[data-breadcrumb-segment="${clientId}"]`)
        if (bcId) bcId.textContent = c.name

        if (headerEl) {
          const contact = [c.contact_email, c.contact_phone].filter(Boolean).join(' · ') || 'Sin datos de contacto.'
          headerEl.innerHTML = `
            <div>
              <h1 class='text-2xl font-bold text-slate-900'>${c.name}</h1>
              <p class='mt-1 text-sm text-slate-500'>${contact}</p>
            </div>
            <div class='flex items-start gap-4'>
              <div class='flex gap-4 text-right text-xs uppercase tracking-widest text-slate-400'>
                <div>
                  <div>Total</div>
                  <div class='text-2xl font-bold tabular-nums text-slate-900'>${s.total}</div>
                </div>
                <div>
                  <div class='text-emerald-500'>Aprobados</div>
                  <div class='text-2xl font-bold tabular-nums text-emerald-700'>${s.passes}</div>
                </div>
                <div>
                  <div class='text-amber-500'>Gamut</div>
                  <div class='text-2xl font-bold tabular-nums text-amber-700'>${s.failures}</div>
                </div>
              </div>
              <button type="button" id="edit-client-btn"
                 class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path>
                  <path d="m15 5 4 4"></path>
                </svg>
                Editar
              </button>
            </div>
          `
        }

        if (infoEl) {
          infoEl.innerHTML = `
            <div class='rounded-lg border border-slate-200 bg-white p-3'>
              <div class='ch-label'>Polímero por defecto</div>
              <div class='text-sm font-semibold uppercase text-slate-800'>${c.default_carrier_polymer ?? '—'}</div>
            </div>
            <div class='rounded-lg border border-slate-200 bg-white p-3 sm:col-span-2'>
              <div class='ch-label'>Notas</div>
              <div class='text-sm text-slate-700'>${c.notes ?? '—'}</div>
            </div>
          `
        }

        const eyebrow = document.querySelector('[data-card-eyebrow]') as HTMLElement | null
        if (eyebrow) eyebrow.textContent = `Cliente · ${c.name}`
      })
      .catch(() => {
        window.location.href = '/dashboard/clients'
      })

    // --- Fetch jobs ---
    const loadJobs = async () => {
      const params = new URLSearchParams()
      params.set('client_id', String(clientId))
      if (fFrom?.value) params.set('date_from', fFrom.value)
      if (fTo?.value) params.set('date_to', fTo.value)
      if (fStatus?.value) params.set('status', fStatus.value)

      const resp = await fetch('/api/jobs?' + params.toString())
      if (!resp.ok) {
        tbody.innerHTML = '<tr><td colspan="7" class="px-3 py-6 text-center text-xs text-rose-600">Fallo al cargar los trabajos.</td></tr>'
        return
      }
      const body = (await resp.json()) as { jobs: Array<{
        id: number
        job_identifier: string | null
        carrier_polymer_used: string | null
        target_l: number | null
        target_a: number | null
        target_b: number | null
        final_delta_e: number | null
        is_success: boolean
        created_at: string
      }> }
      const rows = body.jobs ?? []
      if (rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="px-3 py-6 text-center text-xs text-slate-400">No hay trabajos para este cliente en el rango seleccionado.</td></tr>'
        return
      }
      tbody.innerHTML = rows
        .map((r) => {
          const d = new Date(r.created_at)
          const dateStr = d.toLocaleDateString('es-MX', { year: '2-digit', month: 'short', day: '2-digit' })
          const timeStr = d.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' })
          const status = r.is_success
            ? '<span class="inline-flex items-center rounded-md bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase text-emerald-700">Aprobado</span>'
            : '<span class="inline-flex items-center rounded-md bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase text-amber-700">Gamut</span>'
          const swatch = labToRgbCss(r.target_l, r.target_a, r.target_b)
          const detailUrl = `/dashboard/clients/${clientId}/jobs/${r.id}`

          return `<tr class="border-t border-slate-100 cursor-pointer hover:bg-slate-50" onclick="window.location.href='${detailUrl}'">
            <td class="px-3 py-2.5">
              <a href="${detailUrl}" class="font-mono text-xs text-slate-800 hover:text-blue-600 hover:underline">${r.job_identifier ?? r.id}</a>
            </td>
            <td class="px-3 py-2.5 text-xs text-slate-600">${dateStr} <span class="text-slate-400">${timeStr}</span></td>
            <td class="px-3 py-2.5 text-xs uppercase text-slate-600">${r.carrier_polymer_used ?? '—'}</td>
            <td class="px-3 py-2.5"><div class="h-6 w-8 rounded ring-1 ring-slate-200" style="background: ${swatch}"></div></td>
            <td class="px-3 py-2.5 text-xs tabular-nums text-slate-700">${fmt(r.target_l)}, ${fmt(r.target_a)}, ${fmt(r.target_b)}</td>
            <td class="px-3 py-2.5 text-right text-xs tabular-nums ${r.is_success ? 'text-emerald-700' : 'text-amber-700'}">${r.final_delta_e == null ? '—' : r.final_delta_e.toFixed(2)}</td>
            <td class="px-3 py-2.5 text-right">${status}</td>
          </tr>`
        })
        .join('')
    }

    ;[fFrom, fTo, fStatus].forEach((el) => el?.addEventListener('change', loadJobs))
    loadJobs()
  })
</script>
