---
import DashboardLayout from '@/dashboard/layouts/DashboardLayout.astro'
import Card from '@/dashboard/components/ui/Card.astro'
import ConfirmDialog from '@/dashboard/components/ui/ConfirmDialog.astro'
---

<DashboardLayout
  title='Masterbatch'
  active='calibration-lab'
  breadcrumbLabels={{ new: 'Detalle' }}
  breadcrumbSkipSegments={[]}
>
  {/* Header skeleton */}
  <div id='mb-header' class='mb-6 flex items-start justify-between gap-4'>
    <div>
      <div class='h-7 w-48 animate-pulse rounded bg-slate-200' />
      <div class='mt-2 h-4 w-64 animate-pulse rounded bg-slate-200' />
    </div>
    <div class='flex gap-2'>
      <div class='h-9 w-20 animate-pulse rounded-lg bg-slate-200' />
      <div class='h-9 w-20 animate-pulse rounded-lg bg-slate-200' />
    </div>
  </div>

  {/* Info cards skeleton */}
  <div id='mb-info' class='mb-6 grid gap-4 sm:grid-cols-3'>
    {Array.from({ length: 3 }).map(() => (
      <div class='rounded-lg border border-slate-200 bg-white p-3'>
        <div class='ch-label'>—</div>
        <div class='h-5 w-20 animate-pulse rounded bg-slate-200' />
      </div>
    ))}
  </div>

  {/* Calibration table skeleton */}
  <Card title='Curva de Calibración' eyebrow='Cargando…'>
    <div id='calib-body'>
      <div class='grid gap-3 sm:grid-cols-3'>
        {Array.from({ length: 3 }).map(() => (
          <div class='rounded-lg border border-slate-200 bg-white p-4'>
            <div class='h-4 w-20 animate-pulse rounded bg-slate-200 mb-3' />
            <div class='grid grid-cols-3 gap-2'>
              {Array.from({ length: 3 }).map(() => (
                <div class='h-8 animate-pulse rounded bg-slate-200' />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </Card>

  <ConfirmDialog
    id='delete-mb-dialog'
    title='Eliminar masterbatch'
    message='Esta acción no se puede deshacer. Se eliminarán también los datos de calibración asociados.'
    confirmLabel='Eliminar'
  />
</DashboardLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    // URL guard — see comment on clients/[id].astro for why.
    if (!/^\/dashboard\/calibration-lab\/\d+\/?$/.test(window.location.pathname)) return
    const parts = window.location.pathname.replace(/\/$/, '').split('/')
    const mbId = Number(parts[parts.length - 1])
    if (!Number.isFinite(mbId)) return

    const headerEl = document.getElementById('mb-header')
    const infoEl = document.getElementById('mb-info')
    const calibBody = document.getElementById('calib-body')

    const labToRgbCss = (l: number, a: number, b: number): string => {
      const fy = (l + 16) / 116
      const fx = a / 500 + fy
      const fz = fy - b / 200
      const eps = 216 / 24389
      const kappa = 24389 / 27
      const xr = fx ** 3 > eps ? fx ** 3 : (116 * fx - 16) / kappa
      const yr = l > 8 ? fy ** 3 : l / kappa
      const zr = fz ** 3 > eps ? fz ** 3 : (116 * fz - 16) / kappa
      const X = xr * 0.95047
      const Y = yr * 1.0
      const Z = zr * 1.08883
      let r = X * 3.2406 + Y * -1.5372 + Z * -0.4986
      let g = X * -0.9689 + Y * 1.8758 + Z * 0.0415
      let bl = X * 0.0557 + Y * -0.204 + Z * 1.057
      const toSrgb = (c: number) =>
        c <= 0.0031308 ? 12.92 * c : 1.055 * Math.pow(Math.max(0, c), 1 / 2.4) - 0.055
      r = Math.round(Math.min(1, Math.max(0, toSrgb(r))) * 255)
      g = Math.round(Math.min(1, Math.max(0, toSrgb(g))) * 255)
      bl = Math.round(Math.min(1, Math.max(0, toSrgb(bl))) * 255)
      return `rgb(${r}, ${g}, ${bl})`
    }

    const fmt = (n: number | null) => (n == null ? '—' : n.toFixed(2))

    // Fetch data
    fetch(`/api/masterbatches/${mbId}`)
      .then((r) => r.json())
      .then((data) => {
        if (data.error || !data.masterbatch) {
          window.location.href = '/dashboard/calibration-lab'
          return
        }
        const mb = data.masterbatch
        const providerName = Array.isArray(mb.providers)
          ? mb.providers[0]?.name ?? '—'
          : (mb.providers as { name?: string } | null)?.name ?? '—'

        document.title = `${mb.product_name} · ColorHub`

        // Update breadcrumb
        const bcMb = document.querySelector(`[data-breadcrumb-segment="${mbId}"]`)
        if (bcMb) bcMb.textContent = mb.product_name

        const sourceBadge = mb.calibration_source === 'estimated'
          ? '<span class="ml-2 inline-flex items-center rounded-md bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase text-amber-700" title="Los valores 2% y 15% fueron generados por modelo — validar en planta antes de producción">Estimada</span>'
          : '<span class="ml-2 inline-flex items-center rounded-md bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase text-emerald-700" title="3 chips medidos con espectrofotómetro">Medida</span>'

        if (headerEl) {
          headerEl.innerHTML = `
            <div>
              <div class='flex items-center'>
                <h1 class='text-2xl font-bold text-slate-900'>${mb.product_name}</h1>
                ${sourceBadge}
              </div>
              <p class='mt-1 text-sm text-slate-500'>
                <span class='font-mono text-xs'>${mb.supplier_sku}</span> · ${providerName}
              </p>
            </div>
            <div class='flex flex-shrink-0 gap-2'>
              <a href="/dashboard/calibration-lab/${mbId}/edit"
                 class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path>
                  <path d="m15 5 4 4"></path>
                </svg>
                Editar
              </a>
            </div>
          `
        }

        if (infoEl) {
          const calPoints = (mb.calibration_data ?? []).length
          const badge = calPoints === 3
            ? '<span class="inline-flex items-center rounded-md bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase text-emerald-700">3 / 3</span>'
            : `<span class="inline-flex items-center rounded-md bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase text-amber-700">${calPoints} / 3</span>`
          infoEl.innerHTML = `
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="ch-label">Polímero</div>
              <div class="text-sm font-semibold uppercase text-slate-800">${mb.base_carrier_polymer}</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="ch-label">Stock (kg)</div>
              <div class="text-sm font-semibold tabular-nums text-slate-800">${Number(mb.current_stock_kg ?? 0).toFixed(1)}</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="ch-label">Calibración</div>
              <div class="mt-0.5">${badge}</div>
            </div>
          `
          const eyebrow = document.querySelector('[data-card-eyebrow]') as HTMLElement | null
          if (eyebrow) eyebrow.textContent = mb.color_index_num ?? 'Sin índice'
        }

        // Calibration data
        const calData = (mb.calibration_data ?? []) as Array<{
          id: number
          letdown_percentage: number
          lab_l: number
          lab_a: number
          lab_b: number
        }>
        const sorted = [...calData].sort((a, b) => a.letdown_percentage - b.letdown_percentage)
        const tagMap: Record<number, { label: string; variant: string }> = {
          2: { label: 'Estimado desde 8%', variant: 'standard' },
          15: { label: 'Estimado desde 8%', variant: 'saturation' }
        }

        if (calibBody) {
          calibBody.innerHTML = sorted.length === 0
            ? '<div class="rounded-lg border border-slate-200 bg-slate-50 p-4 text-xs text-slate-500">No hay datos de calibración.</div>'
            : `<div class="grid gap-4 sm:grid-cols-3">
                ${sorted.map((pt) => {
                  const swatch = labToRgbCss(pt.lab_l, pt.lab_a, pt.lab_b)
                  const tag = tagMap[pt.letdown_percentage]
                  return `
                    <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
                      <div class="h-16" style="background: ${swatch}"></div>
                      <div class="p-4">
                        <div class="mb-2 flex items-center justify-between">
                          <h3 class="text-sm font-semibold text-slate-800">${pt.letdown_percentage}%</h3>
                          ${tag ? `<span class="inline-flex items-center rounded-md px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-widest ring-1 ring-inset ${tag.variant === 'standard' ? 'bg-blue-50 text-blue-700 ring-blue-100' : 'bg-violet-50 text-violet-700 ring-violet-100'}">${tag.label}</span>` : ''}
                        </div>
                        <div class="grid grid-cols-3 gap-2 text-center">
                          <div>
                            <div class="text-[10px] font-semibold uppercase text-slate-400">L*</div>
                            <div class="text-sm tabular-nums text-slate-800">${fmt(pt.lab_l)}</div>
                          </div>
                          <div>
                            <div class="text-[10px] font-semibold uppercase text-slate-400">a*</div>
                            <div class="text-sm tabular-nums text-slate-800">${fmt(pt.lab_a)}</div>
                          </div>
                          <div>
                            <div class="text-[10px] font-semibold uppercase text-slate-400">b*</div>
                            <div class="text-sm tabular-nums text-slate-800">${fmt(pt.lab_b)}</div>
                          </div>
                        </div>
                      </div>
                    </div>
                  `
                }).join('')}
              </div>
              ${mb.internal_notes ? `
                <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
                  <div class="ch-label">Notas internas</div>
                  <p class="text-sm text-slate-700">${mb.internal_notes}</p>
                </div>
              ` : ''}
            `
        }
      })
      .catch(() => {
        window.location.href = '/dashboard/calibration-lab'
      })
  })
</script>
