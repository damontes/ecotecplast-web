---
import Layout from '../layouts/Layout.astro'
import SectionHeader from '@/components/home/section-header.astro'
import SectionProducts from '@/components/home/section-products.astro'
import SectionHistory from '@/components/home/section-history.astro'
import SectionAboutUs from '@/components/home/section-about-us.astro'
export const prerender = true
---

<Layout
  title='Ecotecplast - Aditivos y Masterbatch para la Industria del Plástico'
  description='Somos una empresa enfocada en aditivos para el plástico, con más de 20 años de experiencia en el mercado. Fabricamos masterbatch, purgantes y aditivos en pellet para inyección, soplado y extrusión.'
>
  <main class='min-h-screen w-full overflow-hidden'>
    <SectionHeader />
    <SectionProducts />
    <SectionHistory />
    <SectionAboutUs />
  </main>
</Layout>
