---
interface Props {
  active: 'color-matcher' | 'calibration-lab' | 'clients' | 'references'
}

const { active } = Astro.props
const user = Astro.locals.user

const links = [
  { id: 'color-matcher', label: 'Igualador de Color', href: '/dashboard/color-matcher' },
  { id: 'calibration-lab', label: 'Laboratorio de Calibración', href: '/dashboard/calibration-lab' },
  { id: 'references', label: 'Colores de Referencia', href: '/dashboard/references' },
  { id: 'clients', label: 'Clientes', href: '/dashboard/clients' }
] as const
---

<aside class='hidden w-56 shrink-0 flex-col border-r border-slate-200 bg-white md:flex'>
  <div class='px-6 py-6'>
    <div class='text-sm font-bold tracking-tight text-slate-900'>ColorHub</div>
    <div class='text-[10px] font-semibold uppercase tracking-widest text-slate-400'>MVP</div>
  </div>
  <nav class='flex-1 px-3'>
    <ul class='space-y-1'>
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm font-medium transition',
                active === link.id
                  ? 'bg-slate-900 text-white'
                  : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  {
    user && (
      <div class='border-t border-slate-100 px-4 py-4'>
        <div class='mb-2 truncate text-[11px] text-slate-500' title={user.email}>
          {user.email}
        </div>
        <form method='POST' action='/api/auth/logout'>
          <button
            type='submit'
            class='w-full rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 hover:bg-slate-50'
          >
            Cerrar sesión
          </button>
        </form>
      </div>
    )
  }
</aside>
