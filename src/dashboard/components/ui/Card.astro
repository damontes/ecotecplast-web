---
interface Props {
  title?: string
  eyebrow?: string
  right?: string
  class?: string
}

const { title, eyebrow, right, class: className = '' } = Astro.props
const hasRightSlot = Astro.slots.has('right')
---

<section
  class:list={[
    'rounded-lg border border-slate-200 bg-white p-6 shadow-sm',
    className
  ]}
>
  {
    (title || eyebrow || right || hasRightSlot) && (
      <header class='mb-5 flex items-start justify-between gap-4'>
        <div>
          {eyebrow && (
            <div data-card-eyebrow class='text-[10px] font-semibold uppercase tracking-widest text-slate-400'>
              {eyebrow}
            </div>
          )}
          {title && (
            <h2 class='text-base font-semibold text-slate-900'>{title}</h2>
          )}
        </div>
        {hasRightSlot ? (
          <div><slot name='right' /></div>
        ) : right ? (
          <div class='text-xs font-medium text-slate-500'>{right}</div>
        ) : null}
      </header>
    )
  }
  <slot />
</section>
