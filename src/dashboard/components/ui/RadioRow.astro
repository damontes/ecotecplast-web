---
interface Props {
  name: string
  options: { value: string; label: string }[]
  value?: string
}

const { name, options, value } = Astro.props
---

<div class='grid grid-cols-2 gap-3'>
  {
    options.map((opt) => (
      <label class='flex cursor-pointer items-center gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 has-[:checked]:text-slate-900'>
        <input
          type='radio'
          name={name}
          value={opt.value}
          checked={opt.value === value}
          class='h-4 w-4 border-slate-300 text-blue-600 focus:ring-2 focus:ring-blue-500'
        />
        <span>{opt.label}</span>
      </label>
    ))
  }
</div>
