---
import Card from '@/dashboard/components/ui/Card.astro'
import ConcentrationCard from '@/dashboard/components/calibration-lab/ConcentrationCard.astro'
---

<Card title='Curva de Calibración de Color' eyebrow='Curva de 3 puntos' right='UNIDAD: CIELAB (D65/10°)'>
  <div class='space-y-4'>
    <ConcentrationCard
      title='Carga 0.5%'
      idPrefix='calib-05'
      tag='Carga Estándar'
      tagVariant='standard'
    />
    <ConcentrationCard title='Carga 1% (medido)' idPrefix='calib-10' />
    <ConcentrationCard
      title='Carga 2%'
      idPrefix='calib-20'
      tag='Carga de Saturación'
      tagVariant='saturation'
    />
  </div>

  <div class='mt-5 flex items-start justify-between gap-3 rounded-lg bg-sky-50 p-4 ring-1 ring-sky-100'>
    <div class='flex items-start gap-3'>
      <svg
        xmlns='http://www.w3.org/2000/svg'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
        stroke-linecap='round'
        stroke-linejoin='round'
        class='mt-0.5 h-4 w-4 flex-shrink-0 text-sky-600'
      >
        <circle cx='12' cy='12' r='10'></circle>
        <line x1='12' y1='16' x2='12' y2='12'></line>
        <line x1='12' y1='8' x2='12.01' y2='8'></line>
      </svg>
      <p class='text-xs italic text-sky-800'>
        Ingresa el Lab medido de al menos <b>uno</b> de los tres puntos (0.5, 1 o 2%). Al presionar <b>Estimar faltantes</b>, el sistema calcula los puntos vacíos usando el modelo exponencial. Todos los valores quedan editables.
      </p>
    </div>
    <button
      type='button'
      data-estimate-curve
      class='flex-shrink-0 whitespace-nowrap rounded-md bg-sky-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-1'
    >
      Estimar faltantes
    </button>
  </div>
</Card>
