---
import Card from '@/dashboard/components/ui/Card.astro'
import ConcentrationCard from '@/dashboard/components/calibration-lab/ConcentrationCard.astro'
---

<Card title='Curva de Calibración de Color' eyebrow='Curva de 3 puntos' right='UNIDAD: CIELAB (D65/10°)'>
  <div class='space-y-4'>
    <ConcentrationCard
      title='Carga 0.5%'
      idPrefix='calib-05'
      tag='Carga Estándar'
      tagVariant='standard'
    />
    <ConcentrationCard title='Carga 1.0%' idPrefix='calib-10' />
    <ConcentrationCard
      title='Carga 2.0%'
      idPrefix='calib-20'
      tag='Carga de Saturación'
      tagVariant='saturation'
    />
  </div>

  <div class='mt-5 flex items-start gap-3 rounded-lg bg-sky-50 p-4 ring-1 ring-sky-100'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      class='mt-0.5 h-4 w-4 flex-shrink-0 text-sky-600'
    >
      <circle cx='12' cy='12' r='10'></circle>
      <line x1='12' y1='16' x2='12' y2='12'></line>
      <line x1='12' y1='8' x2='12.01' y2='8'></line>
    </svg>
    <p class='text-xs italic text-sky-800'>
      Las coordenadas deben ingresarse manualmente o importarse desde chips de color
      inyectados con espesor uniforme.
    </p>
  </div>
</Card>
